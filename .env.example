# Deriv Personal Access Token (required)
# Create one at https://app.deriv.com/account/api-token
# Required scopes: Read, Trade, Trading Information, Payments
# You can reuse the same token as kairos-trade.
DERIV_TOKEN=

# Deriv App ID (optional — bundled default is used if blank)
DERIV_APP_ID=

# Pin a specific account (e.g. VRTC12345678). Blank = pick first active demo.
DERIV_ACCOUNT_ID=

# Prefer 'demo' or 'real' when the token has both. Default: demo.
HILO_PREFER=demo

# Market defaults (CLI flags override these)
HILO_SYMBOL=1HZ100V
HILO_STAKE=1.0
HILO_CURRENCY=

# Block grid
HILO_BLOCK_MINUTES=3
HILO_BLOCK_TP=1.5

# Trade primitive: 'higher-lower' (breakout bet) or 'no-touch' (stay-in-range bet)
HILO_TRADE_MODE=higher-lower
# Optional halt guards — leave blank to disable
HILO_SESSION_TP=
HILO_SESSION_SL=

# Prediction (port of TimeBlocks.mq5)
HILO_RANGE_MODE=hybrid
HILO_LOOKBACK_DAYS=20
HILO_ATR_BARS=14
HILO_RANGE_K=1.0
