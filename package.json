{
  "name": "hilo-fast",
  "version": "0.1.0",
  "description": "Time-block HIGHER/LOWER CLI for Deriv — ports TimeBlocks.mq5 predicted high/low into automated pair trades",
  "keywords": ["deriv", "trading", "bun", "cli", "hilo", "higher-lower", "time-blocks"],
  "author": "dinethlive <dinethlive@gmail.com>",
  "license": "MIT",
  "type": "module",
  "bin": {
    "hilo-fast": "./src/index.tsx"
  },
  "scripts": {
    "start": "bun src/index.tsx",
    "dev": "bun --watch src/index.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build src/index.tsx --compile --outfile dist/hilo-fast.exe"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "typescript": "^5.6.3"
  }
}
